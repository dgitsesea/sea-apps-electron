{
  "name": "sistema_de_aplicaciones_sesea",
  "version": "5.5.14",
  "description": "Recursos Digitales SEA",
  "repository": {
    "type": "git",
    "url": "https://github.com/dgitsesea/sea-apps-electron.git"
  },
  "author": "SEA Guanajuato <dgit.sesea@guanajuato.gob.mx>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder",
    "release": "electron-builder --publish always",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac --publish always",
    "release:linux": "electron-builder --linux --publish always"
  },
  "build": {
    "appId": "com.sea.dgitsuite",
    "productName": "Recursos Digitales SEA",
    "copyright": "Copyright © 2026 SEA Guanajuato",
    "compression": "maximum",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "dgitsesea",
        "repo": "sea-apps-electron",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "ico.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "icon": "build/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}
