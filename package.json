{
  "name": "plataformadigitalapp",
  "version": "1.0.7",
  "description": "Aplicacion Plataforma Digital",
  "author": "DGIT-SESEA",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -wml",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac --publish always",
    "release:linux": "electron-builder --linux --publish always"
  },
  "build": {
    "appId": "com.sea.pde",
    "productName": "Plataforma Digital",
    "copyright": "Copyright © 2025 SEA Guanajuato",
    "compression": "maximum",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "EmirSESEA",
        "repo": "PlataformaDigitalApp",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "ico.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}